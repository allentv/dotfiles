# Personal identity — fill these in after applying dotfiles:
#   git config --global user.name "Your Name"
#   git config --global user.email "you@example.com"

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true
	side-by-side = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
